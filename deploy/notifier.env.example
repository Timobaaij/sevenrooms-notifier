# ---------------------------------------------------------------------------
# notifier.env — secrets & settings for the watcher (NOT committed to git).
#
# setup.sh copies this to ~/.maitre/notifier.env. Fill in your values there,
# then:  sudo systemctl restart maitre-notifier
# ---------------------------------------------------------------------------

# The mailbox that SENDS alerts (Gmail + an App Password work well).
# Same credentials you use in your GitHub Actions secrets today.
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your-16-char-gmail-app-password

# Pushover email-to-push bridge address (enables "push" notifications).
# Leave blank to disable push. Keeping it here (not in code) means it never
# ships in the repo.
PUSHOVER_EMAIL=

# Fallback address for "email" notifications when a search has no email_to.
# Optional.
EMAIL_TO=

# How often to poll, in seconds. 60 = every minute.
POLL_INTERVAL=60
